{%- assign sticky_btn_url = collection.metafields.custom.button_url.value -%}
{%- assign sticky_btn_text = collection.metafields.custom.button_text -%}

{% if sticky_btn_text != blank %}
  <div class="sticky-btn-section">
    <a
      href="{{ sticky_btn_url }}"
      class="sticky-btn button accent"
    >
      {{ sticky_btn_text | default: 'Shop Now' }}
    </a>
  </div>
{% endif %}

<style>
  .sticky-btn-section {
    display: none;
  }
  @media (max-width: 767px) {
    .sticky-btn-section {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      display: none;
      transition: opacity 0.4s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sticky-btn-section.show {
      opacity: 1;
      pointer-events: auto;
    }
    .sticky-btn {
      height: 56px;
      width: 164px;
      max-width: 100%;
      padding: 0;
    }
  }
</style>

<script>
  (function () {
    const section = document.querySelector('.sticky-btn-section');
    const trigger = document.querySelector('.shopify-section:first-child');
    const footer = document.querySelector('#site-footer');

    if (!section || !trigger) return;

    function checkPosition() {
      if (window.innerWidth > 767) {
        section.style.opacity = '0';
        section.style.pointerEvents = 'none';
        section.classList.remove('show');
        return;
      }

      const triggerBottom = trigger.getBoundingClientRect().bottom;

      if (triggerBottom < -300) {
        section.classList.add('show');
      } else {
        section.classList.remove('show');
        section.style.opacity = '0';
        section.style.pointerEvents = 'none';
        return;
      }

      if (footer) {
        const footerTop = footer.getBoundingClientRect().top;
        const windowHeight = window.innerHeight;
        const fadeZone = 500;
        const distance = footerTop - windowHeight + fadeZone;

        if (distance < fadeZone) {
          const opacity = Math.max(0, distance / fadeZone);
          section.style.opacity = opacity.toFixed(2);
          section.style.pointerEvents = opacity < 0.1 ? 'none' : 'auto';
        } else {
          section.style.opacity = '1';
          section.style.pointerEvents = 'auto';
        }
      } else {
        section.style.opacity = '1';
        section.style.pointerEvents = 'auto';
      }
    }

    window.addEventListener('scroll', checkPosition, { passive: true });
    window.addEventListener('resize', checkPosition, { passive: true });
    checkPosition();
  })();
</script>
