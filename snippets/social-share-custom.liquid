{%- liquid
  assign share_facebook = settings.social_share_facebook
  assign share_twitter = settings.social_share_twitter
  assign share_pinterest = settings.social_share_pinterest
  assign share_whatsapp = settings.social_share_whatsapp
  assign share_clipboard = settings.social_share_clipboard
-%}

<social-share class="share-article share-article-custom" {{ block.shopify_attributes }}>
  {%- if share_label -%}
    <label>{{ 'blogs.article.share' | t }}</label>
  {%- endif -%}

  {%- if share_facebook -%}
    <a href="http://www.facebook.com/sharer.php?u={{ shop.url | append: share_permalink }}" class="facebook social">
      {{ 'social.links.facebook' | t }}
    </a>
  {%- endif %}

  {%- if share_twitter -%}
    <a
      href="https://twitter.com/intent/tweet?text={{ share_title | url_param_escape }}&amp;url={{ shop.url | append: share_permalink }}"
      class="twitter social"
    >
      {{ 'social.links.twitter' | t }}
    </a>
  {%- endif %}

  {%- if share_pinterest -%}
    <a
      href="http://pinterest.com/pin/create/link/?url={{ shop.url | append: share_permalink }}&amp;media={{ share_image | image_url: width: 1024, height: 1024 }}&amp;description={{ share_title | url_param_escape }}"
      class="pinterest social"
    >
      {{ 'social.links.pinterest' | t }}
    </a>
  {%- endif -%}

  {%- if share_whatsapp -%}
    <a
      href="whatsapp://send?text={{ share_title | url_param_escape }}, {{ shop.url | append: share_permalink }}"
      class="whatsapp social"
    >
      {{ 'social.links.whatsapp' | t }}
    </a>
  {%- endif -%}

  {%- if share_clipboard -%}
    <button class="clipboard social">
      <span class="clipboard--bubble">{{ 'social.copied_to_clipboard' | t }}</span>
      {{ 'social.links.copy_link' | t }}
    </button>
  {%- endif -%}
</social-share>

<script src="{{ 'social-share.js' | asset_url }}" defer="defer"></script>
