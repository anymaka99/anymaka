      "blocks": {
        "cd3d35fb-4237-4e0c-b360-523aae405e51": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Does the Insect Net require Canopy Kit poles to set up?",
            "open": false,
            "content": "<p>Yes, the Insect Net requires the poles from the Canopy Kit for setup. We recommend purchasing the Insect Net + Canopy Kit bundle if you don't already have our Canopy Kit. If you already have the Canopy Kit, you can purchase the Insect Net separately.</p>",
            "page": ""
          }
        },
        "5586f39f-c9cc-41a5-9c79-494141a820e1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "What do \"Canopy-On\" and \"Canopy-Off\" modes mean?",
            "open": false,
            "content": "<p>\"Canopy-On\" mode means you use the Canopy Kit and Insect Net together for daylight and insect protection. \"Canopy-Off\" mode means you can remove the canopy and use just the Insect Net, though the poles are still required.</p>",
            "page": ""
          }
        },
        "6e96805a-0713-4c8f-98b5-f7f2996582ee": {
          "type": "collapsible_tab",
          "disabled": true,
          "settings": {
            "heading": "What are its dimensions? How heavy is it?",
            "open": false,
            "content": "<p>Its dimensions are 10*4*4 in / 25.7*10.2*10 cm, weighing only 5.7 oz / 160 g.</p>",
            "page": ""
          }
        }
      },
