    "custom_liquid_QWz8kP": {
      "type": "custom-liquid",
      "settings": {
        "content_for_tab": "tech",
        "text_width": "full_width",
        "custom_liquid": "<!--L-{number} 表示层级关系，相同层级可以换顺序 -->\n\n<!-- L-1 Title -->\n<div class=\"section-header\" style=\"justify-content: center;\">\n  <div class=\"section-header--content\">\n    <h3 class=\"section-header--title text-center\" style=\"color: var(--color-accent);\">\n      Tech Specs\n    </h3>\n  </div>\n</div>\n<!-- End Title-->\n\n<!-- L-1: start Column 1 Row -->\n<div class=\"row\">\n\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Hammock Stand</h5>\n\n      <table class=\"table tech-table no-borders stripes\">\n        <tbody>\n          <tr>\n            <th>Stand Weight</th>\n            <td class=\"text-right\">23 lbs (10.4 kg)</td>\n            <th>Adjustable Points Per Arms</th>\n            <td>8</td>\n          </tr>     \n          <tr>\n            <th>Frame Materials</th>\n            <td class=\"text-right\">Aircraft Grade Aluminum Alloy</td>\n            <th>Folded Dimensions</th>\n            <td>40’’ × 7.5’’ × 9.5’’ (103 cm × 19 cm × 25 cm)</td>            \n          </tr>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td class=\"text-right\">41’’ × 8’’ × 10’’ (104 cm × 20 cm × 26 cm)</td>\n            <th>Total Packed Weight</th>\n            <td>25.3 lbs (10.4 kg)</td>            \n          </tr>\n\n          <tr>\n            <th>Travel Bag Materials</th>\n            <td colspan=\"3\">900D PVC Oxford & 5 mm Foam & 38 mm Polyester Webbing</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n<!-- End Column 1 Row-->\n\n<!-- L-1: start Column 2 Row -->\n<div class=\"row\">\n  \n  <!-- L-2 -->\n  <div class=\"small-12 medium-6 columns\">\n    <div style=\"background: #eee;\">\n      <h5 class=\"h5\" style=\"padding: 10px;margin-bottom: 0;\">Chair Mode</h5>\n      <table class=\"table no-borders\">\n        <tbody>\n          <tr>\n            <th>Ridgeline</th>\n            <td>85’’ (216 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Height</th>\n            <td>44’’ (112 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Footprint</th>\n            <td>62’’ × 44’’ (158 cm × 113 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Max Weight Capacity</th>\n            <td>550 lbs (250 kg)</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>        \n  </div>\n  <!-- End L-2 -->\n  <!-- L-2 -->\n  <div class=\"small-12 medium-6 columns\">\n    <div style=\"background: #eee;\">\n      <h5 class=\"h5\" style=\"padding: 10px;margin-bottom: 0;\">Lounge Mode</h5>    \n      <table class=\"table no-borders\">\n        <tbody>\n          <tr>\n            <th>Ridgeline</th>\n            <td>105’’ (265 cm)</td>\n          </tr>\n          <tr>\n            <th>Height</th>\n            <td>46’’ (116 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Footprint</th>\n            <td>62’’ × 44’’ (158 cm × 113 cm)</td>\n          </tr>\n          <tr>\n            <th>Max Weight Capacity</th>\n            <td>550 lbs (250 kg)</td>\n          </tr>\n        </tbody>\n      </table>    \n    </div>\n  </div>\n  <!-- End L-2 -->\n</div>\n<!-- L-1: start Column 2 Row -->\n<div class=\"row\">\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Ultralight Double Hammock</h5>\n      <table class=\"table no-borders stripes\">  \n        <colgroup>\n          <col width=\"50%\">\n          <col width=\"50%\">\n        </colgroup>\n        <tbody>\n          <tr>\n            <th>Weight</th>\n            <td class=\"text-right\">1.2 lb / 18.3 oz</td>\n          </tr>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td>L 4.3 × W 4.3 × H 6.7 in</td>\n          </tr>\n          <tr>\n            <th>Unpacked Dimensions</th>\n            <td>L 141 × W 86 in</td>\n          </tr>\n          <tr>\n            <th>Capacity</th>\n            <td>2-3 People</td>\n          </tr>\n          <tr>\n            <th>Materials</th>\n            <td class=\"text-right\">40D Diamond Ripstop Nylon</td>\n          </tr>                          \n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n<!-- Cup Holder -->\n<div class=\"row\">\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Quick-install Cup Holder</h5>\n      <table class=\"table no-borders stripes\">  \n        <colgroup>\n          <col width=\"50%\">\n          <col width=\"50%\">\n        </colgroup>\n        <tbody>\n          <tr>\n            <th>Weight</th>\n            <td class=\"text-right\">5.7 oz / 160 g</td>\n          </tr>\n          <tr>\n            <th>Dimensions</th>\n            <td>L 10 × W 4 × H 4 in / L 25.7 × W 10.2 × H 10 cm</td>\n          </tr>\n          <tr>\n            <th>Materials</th>\n            <td class=\"text-right\">Nylon Plastic</td>\n          </tr>                     \n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n\n<!-- Canopy Kit -->\n<div class=\"row\">\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Adjustable Canopy Kit</h5>\n      <table class=\"table no-borders stripes\">  \n        <colgroup>\n          <col width=\"50%\">\n          <col width=\"50%\">\n        </colgroup>\n        <tbody>\n          <tr>\n            <th>Weight</th>\n            <td class=\"text-right\">1.7 lb / 26.5 oz / 750 g</td>\n          </tr>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td>L 3.5 × W 3.5 × H 16 in / L 9 × W 9 × H 41 cm</td>\n          </tr>\n          <tr>\n            <th>Tarp Dimensions</th>\n            <td>L 118 × W 87 in / L 300 × W 220 cm</td>\n          </tr>\n          <tr>\n            <th>Pole Materials</th>\n            <td>8.5 mm Diameter Aluminum Poles</td>\n          </tr>\n          <tr>\n            <th>Tarp Materials</th>\n            <td class=\"text-right\">70D Nylon Ripstop PU450 mm Seams Taped</td>\n          </tr>                     \n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n<!-- Insect Net -->\n<div class=\"row\">\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Insect Net</h5>\n      <table class=\"table no-borders stripes\">  \n        <colgroup>\n          <col width=\"50%\">\n          <col width=\"50%\">\n        </colgroup>\n        <tbody>\n          <tr>\n            <th>Weight</th>\n            <td class=\"text-right\">17.7 oz / 500 g</td>\n          </tr>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td class=\"text-right\">L 4 x W 4.4 x H 11 in / L 10 x W 11 x H 27 cm</td>\n          </tr>\n          <tr>\n            <th>Stuff Sack Materials</th>\n            <td class=\"text-right\">20D Ripstop Nylon</td>\n          </tr>\n          <tr>\n            <th>Net Materials</th>\n            <td class=\"text-right\">Nylon no-see-um bug netting</td>\n          </tr>\n          <tr>\n            <th>Included</th>\n            <td class=\"text-right\">1 × Insect Net</td>\n          </tr>                     \n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>"
      }
