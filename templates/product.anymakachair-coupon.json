      "type": "collapsible-content",
      "blocks": {
        "collapsible_tab_Qhd69Y": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "What is the $10 deposit for?",
            "open": false,
            "content": "<p>The $10 refundable deposit reserves your spot for the launch and locks in the lowest launch price,priority shipping and one of the limited 400 units from this release. Deposit perks are available during the 7-day deposit redemption period after launch.</p>",
            "page": ""
          }
        },
        "collapsible_tab_rt478J": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Is the deposit refundable?",
            "open": false,
            "content": "<p>Yes. Your deposit is <strong>fully refundable</strong> if you decide not to complete your purchase before checkout.</p>",
            "page": ""
          }
        },
        "collapsible_tab_tqQtzj": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "When and how do I use my deposit?",
            "open": false,
            "content": "<p>The Portable Swing Chair officially launches on <strong>March 5, 2026</strong>. You’ll receive an email when sales go live, and you’ll have <strong>7 days after launch</strong> to apply your deposit toward your purchase.</p>",
            "page": ""
          }
        },
        "collapsible_tab_rVtdap": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Does placing a deposit affect my shipping time?",
            "open": false,
            "content": "<p>No. Placing a deposit simply reserves your unit and launch benefits, it does <strong>not delay shipping</strong>.</p>",
            "page": ""
          }
        },
        "collapsible_tab_m9987w": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Who is this release for?",
            "open": false,
            "content": "<p>The anymaka Portable Swing Chair is designed for:</p><ul><li>Camping & motorcycle camping</li><li>Backyard or indoor relaxing</li><li>Picnics with family</li><li>RV trips</li><li>Festivals and outdoor events</li></ul><p>It’s built to be <strong>portable, quiet, and comfortable for all body types</strong>.</p>",
            "page": ""
          }
        },
        "collapsible_tab_NaF7Vm": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "I already own anymaka gear, will this work with my setup?",
            "open": false,
            "content": "<p>Yes. The Portable Swing Chair is designed to work seamlessly with the <strong>existing anymaka system</strong>. Most accessories including the <strong>cup holder and canopy</strong> are compatible across setups.</p>",
            "page": ""
          }
        },
        "collapsible_tab_GTapwb": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Is this release available outside the U.S.?",
            "open": false,
            "content": "<p>For this release, the swing chair is available <strong>in the U.S. only</strong>, with a limited quantity of <strong>400 units</strong>.</p>",
            "page": ""
          }
        }
      },
