    "reviews_new_49wXQ7": {
      "type": "reviews-new",
      "blocks": {
        "review_yyekKw": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">“Super easy to set up and so comfy!”</a>",
            "text": "It is incredibly simple to set up and feels like a dream to relax in. Whether you’re sitting or lying down, it’s the perfect spot to unwind.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Instagrammer@outdooradventure",
            "author_image": "shopify://shop_images/KS_Upate.webp"
          }
        },
        "review_rd3QWm": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">“Perfect for a chill day outside!”</a>",
            "text": "It’s really easy to set up, and feels sturdy. It’s so lightweight and comfortable—I’ve even napped in it during the afternoon sun.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Instagrammer@torylynnnnn",
            "author_image": "shopify://shop_images/555.webp"
          }
        },
        "review_zj8XDn": {
          "type": "review",
          "disabled": true,
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"It gets me into the hammocking vibe instantly!\".</a>",
            "text": "It helps me to rewind and get recovered after daily training. Sometime I also use it as a portable sofa bed at home.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Norris Federick - Long Jump Team USA",
            "author_image": "shopify://shop_images/3.7.webp"
          }
        },
        "review_94V9Mk": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"My daughter and I can stay in it all day.\".</a>",
            "text": "It's very comfortable for my daughter and me, if you‘re looking for a deep connection with nature, anymaka is a reliable companion!\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Katie Wright - Yoga Instructor",
            "author_image": "shopify://shop_images/1_d46862ba-fe1d-412e-8c6d-21fb1fa70ded.webp"
          }
        },
        "review_9NEmKh": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"It changed how I perceived go-anywhere hammocking.\"</a>",
            "text": "It's crazy convenient to use, I can quickly set up the stand to lie down. Unlike other stands that require complicated set-ups or trees.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Marcus Trufant - NFL Member",
            "author_image": "shopify://shop_images/3_963fc14c-9162-40d1-a3ca-6cabc413c27b.webp"
          }
        },
        "review_aLWdUp": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"anymaka is the world's coolest hammock stand!\"</a>",
            "text": "It's an experience like no other. It's not just about holding up your hammock; it's about creating the perfect spot for relaxation and adventure.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Instagrammer@viktoriawanders",
            "author_image": "shopify://shop_images/33_6047e6b5-7c4e-4fed-8458-e633dd79b642.webp"
          }
        },
        "review_FBTAjC": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"It's pretty stable and quite handy.\"</a>",
            "text": "It's super super strong, sort of like parachute material. The space is enough for 2 people to sit on it. I will try to sleep on it for sure!\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Youtuber @Boris The Defender",
            "author_image": "shopify://shop_images/2_1d650b57-84dd-410d-8402-8873fb3fdaeb.webp"
          }
        },
        "review_FNjdjk": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "<a href=\"https://www.anymaka.com/pages/customers-reviews\">\"Setting it up is a breeze.\"</a>",
            "text": "Setting it up was incredibly easy, and the moment it was ready, I knew I had something special. The build quality and attention to detail are outstanding.\n\n<a href=\"https://www.anymaka.com/pages/customers-reviews\">View more ></a>",
            "author": "Instagrammer@wildrnss",
            "author_image": "shopify://shop_images/wildrnss.webp"
          }
        }
      },
