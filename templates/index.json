      "settings": {
        "content_for_tab": "",
        "text_width": "full_width",
        "custom_liquid": "<style>\n  /* 添加字体样式 */\n  @font-face {\n    font-family: 'Swiss 721 Bold';\n    src: url('{{ 'swiss-721-bold.woff' | asset_url }}') format('woff');\n    /* 添加其他字体格式，如果有的话 */\n  }\n\n  /* 添加其他样式 */\n  .custom-section {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: space-between;\n    align-items: flex-start; /* 上下居中 */\n  }\n\n  .text-section {\n    flex: 1;\n    padding: 20px; /* 根据需要调整间距 */\n    box-sizing: border-box;\n  }\n\n  .text-section h2, .text-section p {\n    font-family: 'Swiss 721 Bold', sans-serif; /* 使用Swiss 721 Bold字体 */\n    /* 添加其他文案的样式 */\n  }\n\n  .button-section {\n    text-align: right;\n    padding: 20px; /* 根据需要调整间距 */\n    box-sizing: border-box;\n  }\n\n  .image-section {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: space-between;\n  }\n\n  .image-section img {\n    width: calc(20% - 5px); /* 图片比例为1:1，考虑到边距，总宽度为20% */\n    margin-bottom: 5px; /* 图片间距，根据需要调整 */\n  }\n\n  /* 针对左边上下4个格子 */\n  .image-section img:nth-child(-n+4) {\n    width: calc(40% - 5px); /* 图片比例为1:1，考虑到边距，总宽度为40% */\n  }\n</style>\n\n<div class=\"custom-section\">\n  <div class=\"text-section\">\n    <h2>Your Title</h2>\n    <p>Your Description</p>\n  </div>\n  <div class=\"button-section\">\n    <a href=\"#\" class=\"button\">Your Button</a>\n  </div>\n</div>\n\n<div class=\"image-section\">\n  <img src=\"https://cdn.shopify.com/s/files/1/0747/3440/3866/files/4_22a82276-c0ac-4742-93e1-e969d74681b2.webp?v=1706667338\" alt=\"Image 1\">\n  <img src=\"https://cdn.shopify.com/s/files/1/0747/3440/3866/files/3_500fc626-5933-47de-afc3-51f8559c5fe8.webp?v=1706667337\" alt=\"Image 2\">\n  <img src=\"https://cdn.shopify.com/s/files/1/0747/3440/3866/files/2_0c7382e6-ac82-447c-9adc-2bcb27d823bc.webp?v=1706667338\" alt=\"Image 3\">\n  <img src=\"https://cdn.shopify.com/s/files/1/0747/3440/3866/files/1_f8e7bf5c-133c-4ad4-8e8c-4161ca9d8771.webp?v=1706667337\" alt=\"Image 4\">\n  <img src=\"https://cdn.shopify.com/s/files/1/07