        "content_for_tab": "tech",
        "text_width": "full_width",
        "custom_liquid": "<!--L-{number} 表示层级关系，相同层级可以换顺序 -->\n\n<!-- L-1 Title -->\n<div class=\"section-header\" style=\"justify-content: center;\">\n  <div class=\"section-header--content\">\n    <h3 class=\"section-header--title text-center\" style=\"color: var(--color-accent);\">\n      Tech Specs\n    </h3>\n  </div>\n</div>\n<!-- End Title-->\n\n<!-- L-1: start Column 1 Row -->\n<div class=\"row\">\n\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Hammock Stand</h5>\n\n      <table class=\"table tech-table no-borders stripes\">\n        <tbody>\n          <tr>\n            <th>Stand Weight</th>\n            <td class=\"text-right\">23 lbs (10.4 kg)</td>\n            <th>Adjustable Points Per Arms</th>\n            <td>8</td>\n          </tr>     \n          <tr>\n            <th>Frame Materials</th>\n            <td class=\"text-right\">Aircraft Grade Aluminum Alloy</td>\n            <th>Folded Dimensions</th>\n            <td>40’’ × 7.5’’ × 9.5’’ 103cm × 19 cm × 25 cm</td>            \n          </tr>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td class=\"text-right\">41’’ × 8’’ × 10’’ (104 cm × 20 cm ×26 cm)</td>\n            <th>Total Packed Weight</th>\n            <td>25.3 lbs (10.4 kg)</td>            \n          </tr>\n\n          <tr>\n            <th>Travel Bag Materials</th>\n            <td colspan=\"3\">900D PVC Oxford & 5mm Foam & 38 mm Polyester Webbing</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n<!-- End Column 1 Row-->\n\n<!-- L-1: start Column 2 Row -->\n<div class=\"row\">\n  \n  <!-- L-2 -->\n  <div class=\"small-12 medium-6 columns\">\n    <div style=\"background: #eee;\">\n      <h5 class=\"h5\" style=\"padding: 10px;margin-bottom: 0;\">Chair Mode</h5>\n      <table class=\"table no-borders\">\n        <tbody>\n          <tr>\n            <th>Ridgeline</th>\n            <td>85’’ (216 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Height</th>\n            <td>44’’ (112 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Footprint</th>\n            <td>62’’ × 44’’ (158 cm × 113 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Max Weight Capacity</th>\n            <td>550 lbs (250 kg)</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>        \n  </div>\n  <!-- End L-2 -->\n  <!-- L-2 -->\n  <div class=\"small-12 medium-6 columns\">\n    <div style=\"background: #eee;\">\n      <h5 class=\"h5\" style=\"padding: 10px;margin-bottom: 0;\">Lounge Mode</h5>    \n      <table class=\"table no-borders\">\n        <tbody>\n          <tr>\n            <th>Ridgeline</th>\n            <td>105’’ (265 cm)</td>\n          </tr>\n          <tr>\n            <th>Height</th>\n            <td>46’’ (116 cm)</td>\n          </tr>\n\n          <tr>\n            <th>Footprint</th>\n            <td>62’’ × 44’’ (158 cm × 113 cm)</td>\n          </tr>\n          <tr>\n            <th>Max Weight Capacity</th>\n            <td>550 lbs (250 kg)</td>\n          </tr>\n        </tbody>\n      </table>    \n    </div>\n  </div>\n  <!-- End L-2 -->\n</div>\n<!-- L-1: start Column 2 Row -->"
