        "heading_QYbin3": {
          "type": "heading",
          "settings": {
            "text": "What Happens to My Payments If I Return My Purchase?",
            "marker_style": "style1",
            "size": "h3",
            "marker_color": "#fd6262"
          }
        },
        "text_GJknh6": {
          "type": "text",
          "settings": {
            "text": "<p>If you return your goods, Klarna will automatically reduce the amount you owe. Please note that returnings are subjected to our <a href=\"/pages/return-policy\" title=\"Return Policy\"><span style=\"text-decoration:underline\"><strong>return policy</strong></span></a> pages. If you already paid for a refunded order, Klarna will refund the balance back to your original payment method.</p>",
            "size": "text-size-regular"
          }
        }
      },
