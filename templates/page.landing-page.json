    "reviews_new_qLyHmT": {
      "type": "reviews-new",
      "blocks": {
        "review_48fUmj": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "\"My daughter and I can stay in it all day.\"",
            "text": "It's very comfortable and enjoyable for my daughter and me, if you‘re looking for a deep connection with nature, or into outdoor activities, anymaka is a reliable companion!",
            "author": "Katie Wright - Yoga Instructor",
            "author_image": "shopify://shop_images/1_eaf171a2-3b73-4dd9-86f7-2f16d4611360.webp"
          }
        },
        "review_Wp76eU": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "\"It gets me into the hammocking vibe instantly!\"",
            "text": "It helps me to rewind and get recovered after daily training. Sometime I also use it as a portable sofa bed at home.",
            "author": "Norris Federick - Long Jump Team USA",
            "author_image": "shopify://shop_images/3.7.webp"
          }
        },
        "review_KqNBqa": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "\"It changed how I perceived go-anywhere hammocking.\"",
            "text": "It's crazy convenient to use, I can quickly set up the stand to lie down. Unlike other stands that require complicated set-ups or trees.",
            "author": "Marcus Trufant - NFL Member",
            "author_image": "shopify://shop_images/3_acb4831b-bfc2-4668-a49a-6278bbdfbe93.webp"
          }
        },
        "review_aPQhUW": {
          "type": "review",
          "settings": {
            "stars": "",
            "heading": "\"It's pretty stable and quite handy.\"",
            "text": "It's super super strong, sort of like parachute material. The space is enough for 2 people to sit on it. I will try to sleep on it for sure!",
            "author": "Youtuber @Boris The Defender",
            "author_image": "shopify://shop_images/4_40536e6e-837c-4dc1-8d05-81e144bf2c63.webp"
          }
        }
      },
