    "custom_liquid_QWz8kP": {
      "type": "custom-liquid",
      "settings": {
        "content_for_tab": "tech",
        "text_width": "full_width",
        "custom_liquid": "<!--L-{number} 表示层级关系，相同层级可以换顺序 -->\n\n<!-- L-1 Title -->\n<div class=\"section-header\" style=\"justify-content: center;\">\n  <div class=\"section-header--content\">\n    <h3 class=\"section-header--title text-center\" style=\"color: var(--color-accent);\">\n      Tech Specs\n    </h3>\n  </div>\n</div>\n<!-- End Title-->\n\n<!-- L-1: start Column 1 Row -->\n<div class=\"row\">\n\n  <div class=\"small-12 columns\">\n    <div class=\"\">\n      <h5 class=\"h5\">Hammock Tent</h5>\n\n      <table class=\"table tech-table no-borders stripes\">\n        <tbody>\n          <tr>\n            <th>Packed Dimensions</th>\n            <td colspan=\"3\">L 12.6 × W 6.7 × H 6.7 in (L 32 × W 17 × H 17 cm)</td>\n          </tr>\n          <tr>\n            <th>Packed Weight</th>\n            <td colspan=\"3\">2 lb 13.85 oz (1.3 kg)</td>\n          </tr>\n          <tr>\n            <th>Seasons</th>\n            <td class=\"text-right\">3</td>\n            <th>Door Quantity</th>\n            <td class=\"text-right\">2</td>\n          </tr>\n          <tr>\n            <th>Fabric Materials</th>\n            <td colspan=\"3\">20D Ripstop Nylon</td>\n          </tr>\n          <tr>\n            <th>Mesh Materials</th>\n            <td colspan=\"3\">Nylon no-see-um bug netting</td>\n          </tr>\n          <tr>\n            <th>Included</th>\n            <td colspan=\"3\">\n              1 × Anymaka Hammock Tent<br>\n              1 × Stuff Sack<br>\n              <br>\n              *Hammock not included.<br>\n              *Top Canopy and Poles not included.\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</div>\n<!-- End Column 1 Row-->"
      }
    },
