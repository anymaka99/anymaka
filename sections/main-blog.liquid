{{- 'blog.css' | asset_url | stylesheet_tag -}}
{{- 'blog-custom.css' | asset_url | stylesheet_tag -}}
{%- liquid
  assign blog_layout = section.settings.blog_layout
  assign show_date = section.settings.show_date
  assign show_excerpt = section.settings.show_excerpt
  assign image_ratio = section.settings.image_ratio
  assign show_read_more = section.settings.show_read_more

  case blog_layout
    when 'style1'
      assign per_page = 6
    when 'style2'
      assign per_page = 9
    when 'style3'
      assign per_page = 8
  endcase
-%}

<style>
  #shopify-section-{{ section.id }} .blog-custom {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .blog-custom {
  	padding-top: {{ section.settings.padding_top_mobile }}px;
  	padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

{%- paginate blog.articles by per_page -%}
  <div class="section-spacing-bottom blog-custom">
    <div class="row no-padding">
      <div class="small-12 columns">
        <div class="row articles">
          {%- for article in blog.articles -%}
            {%- liquid
              case blog_layout
                  assign grid_item_width = ''
                when 'style1'
                  assign grid_item_width = 'small-12 medium-6'
                when 'style2'
                  assign grid_item_width = 'small-12 medium-4'
                when 'style3'
                  assign class_1 = 'small-12 medium-4'
                  assign class_2 = 'small-12 medium-6'
                  capture grid_item_width
                    cycle class_1, class_1, class_1, class_2, class_2, class_1, class_1, class_1
                  endcapture
              endcase
            -%}
            <div class="{{ grid_item_width }} columns">
              {% render 'blog-post',
                article: article,
                show_date: show_date,
                show_excerpt: show_excerpt,
                image_ratio: image_ratio,
                show_read_more: show_read_more
              %}
            </div>
          {%- endfor -%}
          <div class="small-12 columns">
            {%- render 'pagination', paginate: paginate, pagination_type: 'paginated' -%}
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Blog posts",
  "class": "blog-section",
  "settings": [
    {
      "type": "select",
      "id": "blog_layout",
      "label": "Layout",
      "default": "style3",
      "options": [
        { "value": "style1", "label": "2 columns" },
        { "value": "style2", "label": "3 columns" },
        { "value": "style3", "label": "3 - 2 - 3 columns" }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "landscape",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "Show excerpt"
    },
    {
      "type": "paragraph",
      "content": "Change excerpts by editing your blog posts. [Learn more](https://help.shopify.com/en/manual/online-store/blogs/writing-blogs#display-an-excerpt-from-a-blog-post)"
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "default": true,
      "label": "Show read more"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 64
    }
  ]
}
{% endschema %}
