{{ 'timeline.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .timeline {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 1067px) {
    #shopify-section-{{ section.id }} .timeline {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

<section class="timeline">
  {% if section.settings.title != blank %}
    <h2 class="timeline__title">{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="timeline__list">
      {% for block in section.blocks %}
        <article
          class="item"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.date != blank %}
            <div class="date">{{ block.settings.date }}</div>
          {% endif %}

          <div class="card">
            {% if block.settings.heading != blank %}
              <h3>{{ block.settings.heading }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}

            {% assign has_images = false %}
            {% if block.settings.image_1 != blank
              or block.settings.image_2 != blank
              or block.settings.image_3 != blank
            %}
              {% assign has_images = true %}
            {% endif %}

            {% if has_images %}
              <div class="timeline__images {% if block.settings.images_flex == 'row' %}images-flex{%else%}images-column{% endif %}">
                {% for i in (1..3) %}
                  {% assign image_key = 'image_' | append: i %}
                  {% assign image = block.settings[image_key] %}

                  {% if image != blank %}
                    <img
                      src="{{ image | image_url: width: 700 }}"
                      alt="{{ block.settings.heading | escape }}"
                      class="image"
                      loading="lazy"
                    >
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Timeline",
  "tag": "section",
  "class": "section-timeline",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Journey"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Timeline item",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2024"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Milestone"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Describe your milestone here."
        },
        {
          "type": "select",
          "id": "images_flex",
          "label": "Display images in a row (desktop)",
          "default": "column",
          "options": [
            { "value": "row", "label": "Row" },
            { "value": "column", "label": "Column" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
