          "label": "Text",
          "info": "优先显示Custom Html,如果Custom Html有值的话"
        },
        {
          "type": "liquid",
          "id": "custom_html",
          "label": "Custom Html",
          "info": "优先显示Custom Html"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "id": "heading_size_desktop",
          "type": "number",
          "label": "Heading Size on Desktop",
          "info": "px"
        },
        {
          "id": "text_size_desktop",
          "type": "number",
          "label": "Text Size on Desktop",
          "info": "px"
        },
        {
          "id": "heading_size_mobile",
          "type": "number",
          "label": "Heading Size on Mobile",
          "info": "px"
        },
        {
          "id": "text_size_mobile",
          "type": "number",
          "label": "Text Size on Mobile",
          "info": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "timeline"
        },
        {
          "type": "timeline"
        },
        {
          "type": "timeline"
        }
      ]
    }
  ]
}
{% endschema %}
