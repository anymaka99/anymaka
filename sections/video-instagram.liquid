<section class="how-used">
  <div class="page-width">
    <h2 class="how-used__title">
      {{ section.settings.title }}
    </h2>

    <div class="swiper how-used__slider">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide how-used__slide">
            <div class="how-used__video-wrap">
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<style>
  .how-used {
    padding: 80px 0;
  }

  .how-used__title {
    font-size: 42px;
    font-weight: 600;
    margin-bottom: 32px;
  }

  .how-used__slide {
    border-radius: 20px;
    overflow: hidden;
  }

  .how-used__video-wrap {
    position: relative;
    aspect-ratio: auto;
    height: 600px;
    background: #000;
  }

  @media (max-width: 767px) {
    .how-used__video-wrap {
      aspect-ratio: 4 / 5;
      height: auto;
    }
  }

  .how-used__video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .how-used__video-wrap {
    aspect-ratio: auto;
    height: 600px;
  }
  @media (max-width: 1200px) {
    .how-used__video-wrap {
      height: auto;
      aspect-ratio: 4 / 5;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sliders = document.querySelectorAll('.how-used__slider');

    sliders.forEach((slider) => {
      new Swiper(slider, {
        slidesPerView: 'auto',
        spaceBetween: 24,
        centeredSlides: true,
        loop: true,

        breakpoints: {
          0: {
            slidesPerView: 1.2,
            spaceBetween: 12,
          },
          768: {
            slidesPerView: 2.2,
            spaceBetween: 16,
          },
          1024: {
            slidesPerView: 3.2,
            spaceBetween: 24,
          },
          1440: {
            slidesPerView: 4.2,
            spaceBetween: 24,
          },
        },
      });
    });
  });
</script>

{% schema %}
{
  "name": "Instagram video slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How It's Used"
    }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Instagram video slider"
    }
  ]
}
{% endschema %}
