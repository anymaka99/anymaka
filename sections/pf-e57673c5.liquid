        credentials: 'same-origin',
        body: JSON.stringify({
          line: index,
          quantity: 0
        })
      })
        .then(response => response.json())
        .then(data => {
          if (data.items) {
            // Update cart UI here
            console.log('Item removed successfully');
          } else {
            console.error('Error removing item');
          }
        })
        .catch(error => console.error('Error:', error));
    });
  });
