{{- 'product-scroll-nav.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-nav-scroll.js' | asset_url }}" defer="defer"></script>

<style>
  .product-nav-scroll-section {
      background-color: {{ settings.color_body_bg }};
  }
</style>

{%- liquid
  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing
  assign color_bg = section.settings.color_bg | downcase
  assign color_text = section.settings.color_text
  assign color_tabs = section.settings.color_tabs
  assign color_body_bg = settings.color_body_bg | downcase

  assign has_bg = true
  if color_body_bg == color_bg or color_bg == 'transparent' or color_bg == 'rgba(0,0,0,0)'
    assign has_bg = false
  endif
-%}

<div class="row" id="product-tab-switch">
  <div class="small-12 columns">
    <div
      class="product-nav-scroll-wrapper {% if has_bg -%}product-nav-scroll--has-bg{% endif %} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
      data-product-nav-scroll
      style="--product-nav-bg: {{ color_bg }}; --product-nav-text: {{ color_text }}; --product-nav-links: {{ color_tabs.rgb | replace: ' ' , ',' }};"
    >
      <nav class="product-nav-scroll" aria-label="Product sections">
        <div class="product-nav-scroll__inner">
          {%- for block in section.blocks -%}
            {%- assign label = block.settings.tab_label -%}
            {%- assign target_id = block.settings.target_selector | default: block.settings.tab_label | handle -%}
            {%- if label != blank and target_id != blank -%}
              <a
                class="product-nav-scroll__link{% if forloop.index == 1 %} is-active{%- endif -%}"
                href="#{{ target_id }}"
                data-target-id="{{ target_id }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.icon != blank and block.settings.icon != 'none' %}
                  {% render 'svg-icons-inline', icon: block.settings.icon %}
                {% endif %}
                <span>{{ label }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </nav>
    </div>
  </div>
</div>

