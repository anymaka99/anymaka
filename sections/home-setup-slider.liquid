{{ 'home-setup-slider.css' | asset_url | stylesheet_tag }}

<style>
  .setup-slider {
    background-color: {{ section.settings.bg_color }};
  }

  #shopify-section-{{ section.id }} .setup-slider {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .setup-slider {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
</style>

<section class="setup setup-slider">
  <div class="setup__content">
    <div class="setup__text">
      {% if section.settings.show_line %}
        {%- render 'icon-setup-line' -%}
      {% endif %}
      {% for block in section.blocks %}
        <div
          class="setup__text-block {% if forloop.first %}setup__text-block--active{% endif %}"
          data-slide="{{ forloop.index0 }}"
        >
          <h2 class="setup__title">{{ block.settings.title }}</h2>
          <p class="setup__desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

    <div class="setup__hammocks" role="tablist" aria-label="Choose a hammock">
      {% for block in section.blocks %}
        <button
          class="setup__hammock {% if forloop.first %}setup__hammock--active{% endif %}"
          type="button"
          data-slide="{{ forloop.index0 }}"
          role="tab"
          aria-controls="setup-video-{{ forloop.index }}"
        >
          {% if block.settings.hammock_thumb %}
            <img src="{{ block.settings.hammock_thumb | image_url: width: 200 }}" alt="">
          {% endif %}
        </button>
      {% endfor %}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="setup__nav" aria-label="Hammock slides">
        <button class="setup__nav-btn setup__nav-btn--prev" type="button" aria-label="Previous slide">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.83333 7.14583L6.91667 11.2292C7.08333 11.3958 7.16319 11.5903 7.15625 11.8125C7.14931 12.0347 7.0625 12.2292 6.89583 12.3958C6.72917 12.5486 6.53472 12.6285 6.3125 12.6354C6.09028 12.6424 5.89583 12.5625 5.72917 12.3958L0.229167 6.89583C0.145833 6.8125 0.0868056 6.72222 0.0520833 6.625C0.0173611 6.52778 0 6.42361 0 6.3125C0 6.20139 0.0173611 6.09722 0.0520833 6C0.0868056 5.90278 0.145833 5.8125 0.229167 5.72917L5.72917 0.229167C5.88194 0.0763889 6.07292 0 6.30208 0C6.53125 0 6.72917 0.0763889 6.89583 0.229167C7.0625 0.395833 7.14583 0.59375 7.14583 0.822917C7.14583 1.05208 7.0625 1.25 6.89583 1.41667L2.83333 5.47917H12.1458C12.3819 5.47917 12.5799 5.55903 12.7396 5.71875C12.8993 5.87847 12.9792 6.07639 12.9792 6.3125C12.9792 6.54861 12.8993 6.74653 12.7396 6.90625C12.5799 7.06597 12.3819 7.14583 12.1458 7.14583H2.83333Z"
                  fill="#242528"/>
          </svg>
        </button>
        <button class="setup__nav-btn setup__nav-btn--next" type="button" aria-label="Next slide">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.83333 7.14583L6.91667 11.2292C7.08333 11.3958 7.16319 11.5903 7.15625 11.8125C7.14931 12.0347 7.0625 12.2292 6.89583 12.3958C6.72917 12.5486 6.53472 12.6285 6.3125 12.6354C6.09028 12.6424 5.89583 12.5625 5.72917 12.3958L0.229167 6.89583C0.145833 6.8125 0.0868056 6.72222 0.0520833 6.625C0.0173611 6.52778 0 6.42361 0 6.3125C0 6.20139 0.0173611 6.09722 0.0520833 6C0.0868056 5.90278 0.145833 5.8125 0.229167 5.72917L5.72917 0.229167C5.88194 0.0763889 6.07292 0 6.30208 0C6.53125 0 6.72917 0.0763889 6.89583 0.229167C7.0625 0.395833 7.14583 0.59375 7.14583 0.822917C7.14583 1.05208 7.0625 1.25 6.89583 1.41667L2.83333 5.47917H12.1458C12.3819 5.47917 12.5799 5.55903 12.7396 5.71875C12.8993 5.87847 12.9792 6.07639 12.9792 6.3125C12.9792 6.54861 12.8993 6.74653 12.7396 6.90625C12.5799 7.06597 12.3819 7.14583 12.1458 7.14583H2.83333Z"
                  fill="#242528"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  </div>

  <div class="setup__media">
    <div class="swiper setup__swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide setup__slide" id="setup-video-{{ forloop.index }}">
            <div class="setup__media-frame">
              {% if block.settings.video %}
                {{ block.settings.video | video_tag: muted: true, autoplay: true, loop: true, controls: false }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="pagination"></div>
</section>

<script>
  function initSetupSlider(section) {
    const root = section || document;
    const swiperEl = root.querySelector('.setup__swiper');
    if (!swiperEl || typeof Swiper === 'undefined') return;

    const setupTextBlocks = root.querySelectorAll('.setup__text-block');
    const setupThumbs = root.querySelectorAll('.setup__hammock');

    if (swiperEl.swiper) {
      swiperEl.swiper.destroy(true, true);
    }

    const setupSwiper = new Swiper(swiperEl, {
      slidesPerView: 1,
      speed: 400,
      loop: true,
      spaceBetween: 40,
      navigation: {
        nextEl: root.querySelector('.setup__nav-btn--next'),
        prevEl: root.querySelector('.setup__nav-btn--prev'),
      },
      pagination: {
        el: root.querySelector('.pagination'),
        clickable: true,
      },
      on: {
        slideChange(swiper) {
          const realIndex = swiper.realIndex;

          setupThumbs.forEach((thumb, index) => {
            thumb.classList.toggle('setup__hammock--active', index === realIndex);
          });

          setupTextBlocks.forEach((block, index) => {
            block.classList.toggle('setup__text-block--active', index === realIndex);
          });

          setTimeout(() => {
            root.querySelectorAll('.setup__media-frame video').forEach((video) => {
              video.pause();
              video.currentTime = 0;
            });

            const activeSlide = swiper.slides[swiper.activeIndex];
            const activeVideo = activeSlide.querySelector('video');
            if (activeVideo) activeVideo.play();
          }, 400);
        },
      },
    });

    setupThumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = Number(thumb.dataset.slide);
        setupSwiper.slideToLoop(index);
      });
    });

    setupSwiper.emit('slideChange');
  }

  document.querySelectorAll('.setup-slider').forEach((section) => {
    initSetupSlider(section);
  });

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.classList.contains('setup-slider')) {
      initSetupSlider(e.target);
    }
  });
</script>

{% schema %}
{
  "name": "Setup Slider",
  "class": "setup-slider",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "checkbox",
      "id": "show_line",
      "label": "Show title line"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section padding top (mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section padding bottom (mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section padding top (desktop)",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Section padding bottom (desktop)",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Slide item",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "hammock_thumb",
          "label": "Hammock thumbnail"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Setup Slider"
    }
  ]
}
{% endschema %}
