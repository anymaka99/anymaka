{{- 'multicolumn.css' | asset_url | stylesheet_tag -}}
{%- liquid
	assign section_heading = section.settings.heading
	assign marker_style = section.settings.marker_style
	assign section_description = section.settings.description
	assign columns_desktop = section.settings.columns_desktop
	assign heading_size = section.settings.heading_size
	assign heading_font = section.settings.heading_font
	assign mobile_swipe = section.settings.mobile_swipe
	assign image_ratio = section.settings.image_ratio
	assign text_alignment = section.settings.text_alignment

	assign color_heading = section.settings.color_heading
	assign marker_color = section.settings.marker_color
	assign color_text = section.settings.color_text
	assign color_links = section.settings.color_links

	assign disable_top_spacing = section.settings.disable_top_spacing
	assign disable_bottom_spacing = section.settings.disable_bottom_spacing
    assign btn_class = section.settings.link_style | append: " " | append: section.settings.button_size | append: " " | append: section.settings.block_link_font
    
	case columns_desktop
        when 1
			assign columns_desktop_class = 'medium-12'
		when 2
			assign columns_desktop_class = 'medium-6'
		when 3
			assign columns_desktop_class = 'medium-4'
		when 4
			assign columns_desktop_class = 'medium-3'
		when 5
			assign columns_desktop_class = 'medium-1/5 large-1/5'
	endcase
-%}
<div {% if section.settings.section_id != blank %} id="{{ section.settings.section_id }}" {% endif %} class="{% if section.settings.content_for_tab != blank %}product-tabs-content js-product-tabs-content-{{ section.settings.content_for_tab }}{% endif %} multicolumn {% if mobile_swipe %} swipe-on-mobile{% endif %} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %} text-alignment--{{ text_alignment }}" style="--color-heading: {{ color_heading }}; --color-text: {{ color_text }}; --color-accent: {{ color_links }}; --color-accent-rgb: {{ color_links.rgb | replace: ' ' , ',' }};">
	<div class="row row-{{ section.id }}">
		<div class="small-12 columns">
			{% render 'section-header', section_heading: section_heading, heading_font: heading_font, section_description: section_description, marker_color: marker_color, marker_style: marker_style %}

           {% if section.settings.link_label != blank %}
            <div class="multicolumn-btn-wrap"> 
                {% render 'text-button', url: section.settings.link, title: section.settings.link_label, class: btn_class %}
            </div>
            {% endif %}
			<div class="multicolumn__inner text-{{ text_alignment }}">
				<div class="row align-stretch no-padding no-margin-{{ section.settings.no_margin }} {% if section.settings.layout_grid %} grid-row{% endif %}">
                 
                  {%-  if section.settings.enable_carousel -%}<slide-show class="customer-reviews--carousel multi-column--carousel multi-column--carousel-{{ section.settings.slide_arrow }}">{%- endif -%}
					{%- for block in section.blocks -%}
                        {%- liquid 	
                            assign columns_mobile = block.settings.columns_mobile
                            case columns_mobile
                                when 1
                        			assign columns_mobile_class = 'small-12'
                        		when 2
                        			assign columns_mobile_class = 'small-6'
                        		when 3
                        			assign columns_mobile_class = 'small-4'
                           		when 4
                        			assign columns_mobile_class = 'small-3'
                        	endcase
                        -%}                      
						<div class="multicolumn__column {% if block.settings.only_mobile %} div-label--mobile{% endif %} {% if mobile_swipe %} small-12 {% else %} {{ columns_mobile_class }}{% endif %} {% if section.settings.enable_carousel %} carousel__slide{% endif %} {{ columns_desktop_class }} columns text-{{ block.settings.text_alignment }} multicolumn__column-{{ forloop.first }}">
							{% if block.settings.image != blank %}
								{%- liquid
									assign ratio = 1
									assign max_width = block.settings.image.width | divided_by: 2 | append: 'px'
									assign image_link = block.settings.image_link
									if image_ratio == 'adapt'
										assign ratio = block.settings.image.aspect_ratio
									endif
									if block.settings.image_full_width
										assign max_width = '100%'
									endif
								-%}
								<figure class="multicolumn__image" style="width: {{ max_width }};">
									<div class="multicolumn__image--inner aspect-ratio aspect-ratio--{{ image_ratio }}" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
										{% if image_link != blank %}
											<a href="{{ image_link }}">
										{% endif %}
										{%- render 'responsive-image', image: block.settings.image, sizes: '407x0,814x0', retina: true -%}
										{% if image_link != blank %}
											</a>
										{% endif %}
									</div>
								</figure>
							{% endif %}
							{% if block.settings.title != blank %}
								<h4 class="{{ heading_size }} {{ section.settings.block_heading_font }}">{{ block.settings.title | newline_to_br }}</h4>
							{% endif %}
							{% if block.settings.text != blank %}
								<div class="rte {{ section.settings.block_description_font }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
							{% endif %}
							{% if block.settings.link_label != blank %}
                
								{% render 'text-button', url: block.settings.link, title: block.settings.link_label, class: btn_class %}
							{% endif %}
						</div>
					{%- endfor -%}
                   {%-  if section.settings.enable_carousel -%}
                      
                        <div class="flickity-nav flickity-prev" tabindex="0">{% render 'svg-icons' with 'carousel-prev' %}</div>
                        <div class="flickity-nav flickity-next" tabindex="0">{% render 'svg-icons' with 'carousel-next' %}</div>
                      
                     </slide-show>
                 {%- endif -%}
				</div>
			</div>
		</div>
	</div>
</div>
<style>

.row-{{ section.id }}.row .columns {
    padding: 0 {{ section.settings.multicolum_padding_mobile }}px;
}
.row-{{ section.id }}.row .section-header--title{
  color: {{ section.settings.color_section_heading }};
}
.row-{{ section.id }}.row .section-header--description{
  color: {{ section.settings.color_section_desc}};
}
@media only screen and (max-width: 767px){
 
  .row-{{ section.id }}.row .grid-row .columns {
      padding: 1px 1px;
  } 
}
@media only screen and (min-width: 768px){
  .row-{{ section.id }}.row .columns {
      padding: 0 {{ section.settings.multicolum_padding_pc }}px;
  }
  {%- if section.settings.heading_width > 0 -%}
  .row-{{ section.id }}.row .section-header--content{
    max-width: {{ section.settings.heading_width }}px;
  }
  {%- endif -%}

  .row-{{ section.id }} .grid-row{
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(2, 1fr);
  }
  .row-{{ section.id }} .grid-row .multicolumn__column.multicolumn__column-true {
    grid-column: span 2;
    grid-row: span 2;
  }
  .row-{{ section.id }} .grid-row .multicolumn__column {
    max-width: 100%!important;
  }
}


  
</style>
