{{ 'collection-video-slider.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .product-list {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .product-list {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .product-list {
        background-color: {{ section.settings.bg_color }};
      }
  }
</style>

<section class="product-list">
  {% if section.settings.title != blank %}
    <h2 class="product-list__title">
      {{ section.settings.title }}
      {% if section.settings.show_line and section.settings.vector_image != blank %}
        <img
          class="product-list__vector"
          src="{{ section.settings.vector_image | image_url: width: 200 }}"
          alt=""
          aria-hidden="true"
          loading="lazy"
        >
      {% endif %}
    </h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="product-list__slider">
      <div class="swiper product-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide product-card" {{ block.shopify_attributes }}>
              {% if block.settings.video != blank %}
                {{
                  block.settings.video
                  | video_tag:
                    muted: true,
                    loop: true,
                    playsinline: true,
                    preload: 'metadata',
                    class: 'product-card__media'
                }}
              {% endif %}

              <div class="product-card__gradient" aria-hidden="true"></div>

              {% if block.settings.tagline != blank %}
                <p class="product-card__tagline">{{ block.settings.tagline }}</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>

        <span class="product-list__cursor" aria-hidden="true"></span>
      </div>

      <div class="pagination"></div>
    </div>
  {% endif %}
</section>

<script>
  (function () {
    const initProductList = () => {
      document.querySelectorAll('#shopify-section-{{ section.id }} .product-list').forEach((root) => {
        const sliderEl = root.querySelector('.product-swiper');
        const paginationEl = root.querySelector('.pagination');
        const cursorEl = root.querySelector('.product-list__cursor');

        if (!sliderEl || typeof Swiper === 'undefined') return;

        if (sliderEl.swiper) {
          sliderEl.swiper.destroy(true, true);
        }

        const swiper = new Swiper(sliderEl, {
          init: false,
          slidesPerView: 'auto',
          spaceBetween: 16,
          centeredSlides: true,
          loop: true,
          pagination: {
            el: paginationEl,
            clickable: true,
          },
          breakpoints: {
            0: { spaceBetween: 12 },
            1024: { spaceBetween: 16 },
          },
        });

        const syncActiveVideo = () => {
          sliderEl.querySelectorAll('.swiper-slide').forEach((slide) => {
            const video = slide.querySelector('video');
            if (!video) return;

            if (slide.classList.contains('swiper-slide-active')) {
              video.play().catch(() => {});
            } else {
              video.pause();
              video.currentTime = 0;
            }
          });
        };

        swiper.on('init', syncActiveVideo);
        swiper.on('slideChangeTransitionEnd', syncActiveVideo);
        swiper.init();

        if (paginationEl) {
          paginationEl.style.display = 'flex';
        }

        const enableCursor = window.matchMedia('(min-width: 1025px)').matches;

        if (cursorEl && enableCursor) {
          const updateCursor = (event) => {
            const rect = sliderEl.getBoundingClientRect();
            const x = event.clientX - rect.left;
            const y = event.clientY - rect.top;
            const isLeft = x < rect.width / 2;

            cursorEl.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%)`;
            cursorEl.classList.toggle('is-left', isLeft);
            cursorEl.classList.toggle('is-right', !isLeft);
          };

          sliderEl.addEventListener('mouseenter', (event) => {
            sliderEl.classList.add('is-hovered');
            updateCursor(event);
          });

          sliderEl.addEventListener('mousemove', updateCursor);

          sliderEl.addEventListener('mouseleave', () => {
            sliderEl.classList.remove('is-hovered');
          });

          sliderEl.addEventListener('click', (event) => {
            const rect = sliderEl.getBoundingClientRect();
            const isLeft = event.clientX - rect.left < rect.width / 2;
            if (isLeft) {
              swiper.slidePrev();
            } else {
              swiper.slideNext();
            }
          });
        }
      });
    };

    initProductList();

    document.addEventListener('shopify:section:load', initProductList);
    document.addEventListener('shopify:section:reorder', initProductList);
    document.addEventListener('shopify:section:select', initProductList);
  })();
</script>

{% schema %}
{
  "name": "Collection video slider",
  "class": "product-list-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "The Magic of a Hammock"
    },
    {
      "type": "checkbox",
      "id": "show_line",
      "label": "Show title curve",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "vector_image",
      "label": "Title curve image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Product card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Card video"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline text",
          "default": "Where design meets the weekend."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection video slider"
    }
  ]
}
{% endschema %}
