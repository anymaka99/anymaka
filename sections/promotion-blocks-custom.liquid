{{- 'promotion-blocks.css' | asset_url | stylesheet_tag -}}
{{- 'promotion-blocks-custom.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign column_spacing = section.settings.column_spacing
  assign mobile_swipe = section.settings.mobile_swipe
  assign image_ratio = section.settings.image_ratio

  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing
-%}
<div
  class="promotion-blocks prom-custom{% if mobile_swipe %} swipe-on-mobile{% endif %} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
  style="--column-size: {{ section.blocks.size }};"
>
  <div class="promotion-blocks--inner column-spacing--{{ column_spacing }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign ratio = 1
        if image_ratio == 'adapt' and block.settings.image
          assign ratio = block.settings.image.aspect_ratio
        endif
      -%}
      <div class="promotion-blocks--item" {{ block.shopify_attributes }}>
        <div class="promotion-blocks--text">
          {% if block.settings.title != blank %}
            <h6>{{ block.settings.title }}</h6>
          {% endif %}
          {% if block.settings.button_text != blank %}
            <a class="button accent" href="{{ block.settings.button_link }}">
              {{ block.settings.button_text }}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <mask id="mask0_4569_2503" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="20" height="20">
                <rect width="20" height="20" fill="#D9D9D9"/>
                </mask>
                <g mask="url(#mask0_4569_2503)">
                <path d="M13.334 6.99984L5.91732 14.4165C5.76454 14.5693 5.5701 14.6457 5.33398 14.6457C5.09787 14.6457 4.90343 14.5693 4.75065 14.4165C4.59787 14.2637 4.52148 14.0693 4.52148 13.8332C4.52148 13.5971 4.59787 13.4026 4.75065 13.2498L12.1673 5.83317H5.83398C5.59787 5.83317 5.39996 5.75331 5.24023 5.59359C5.08051 5.43386 5.00065 5.23595 5.00065 4.99984C5.00065 4.76373 5.08051 4.56581 5.24023 4.40609C5.39996 4.24637 5.59787 4.1665 5.83398 4.1665H14.1673C14.4034 4.1665 14.6013 4.24637 14.7611 4.40609C14.9208 4.56581 15.0007 4.76373 15.0007 4.99984V13.3332C15.0007 13.5693 14.9208 13.7672 14.7611 13.9269C14.6013 14.0866 14.4034 14.1665 14.1673 14.1665C13.9312 14.1665 13.7333 14.0866 13.5736 13.9269C13.4138 13.7672 13.334 13.5693 13.334 13.3332V6.99984Z" fill="#F79009"/>
                </g>
              </svg>
            </a>
          {% endif %}
        </div>
        {% if block.settings.image != blank %}
          <figure class="promotion-blocks--image">
            <div
              class="aspect-ratio aspect-ratio--{{ image_ratio }}"
              style="--ratio-percent:{{ 1.0 | divided_by: ratio | times: 100.0 }}%;"
            >
              {%- render 'responsive-image', image: block.settings.image, sizes: '120x0,240x0' -%}
            </div>
          </figure>
        {% endif %}
        {% if block.settings.block_link != blank %}
          <a href="{{ block.settings.block_link }}" class="promotion-blocks--link"></a>
        {% endif %}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Promotion blocks custom",
  "class": "section-promotion-blocks",
  "max_blocks": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "mobile_swipe",
      "default": false,
      "label": "Enable swipe on mobile"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "select",
      "id": "column_spacing",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium",
      "label": "Column spacing"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_top_spacing",
      "default": false,
      "label": "Remove top spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_bottom_spacing",
      "default": false,
      "label": "Remove bottom spacing"
    }
  ],
  "blocks": [
    {
      "type": "promotion",
      "name": "Promotion",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "690 x 690 .jpg recommended."
        },
        {
          "type": "text",
          "id": "title",
          "default": "Promotion heading",
          "label": "Heading"
        },
        {
          "id": "button_text",
          "type": "text",
          "label": "Button label",
          "default": "Explore",
          "info": "Leave the label blank to hide the button."
        },
        {
          "id": "button_link",
          "type": "url",
          "label": "Button link"
        },
        {
          "id": "block_link",
          "type": "url",
          "label": "Block link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotion blocks custom",
      "blocks": [
        {
          "type": "promotion"
        },
        {
          "type": "promotion"
        },
        {
          "type": "promotion"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["header", "footer"]
  }
}
{% endschema %}
