        },
        {
          "type": "text",
          "id": "item_text_4",
          "label": "Item text 4"
        },
        {
          "type": "image_picker",
          "id": "item_image_5",
          "label": "Item image 5"
        },
        {
          "type": "text",
          "id": "item_text_5",
          "label": "Item text 5"
        }
