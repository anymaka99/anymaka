{%- liquid
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height
  assign full_width = section.settings.full_width
  assign fallback_image = section.settings.fallback_image
  assign fallback_image_mobile = section.settings.fallback_image_mobile
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign video = section.settings.video
  assign video_hosted = section.settings.video_hosted
  assign video_controls = section.settings.video_controls
  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing

  if video_hosted == blank
    assign video_type = video.type
  else
    assign video_type = 'hosted'
  endif
-%}

<style>
  .button_block a {
    background-color: {{ section.settings.bg_button }};
    color: {{ section.settings.color_button }};
    border: 1px solid {{ section.settings.border_color }};
  }
  .button_block a:hover {
    background-color: {{ section.settings.bg_button_hover }};
    color: {{ section.settings.color_button_hover }};
    border: 1px solid {{ section.settings.border_color_hover }};
  }

  .button_block-link.mobile {
    background-color: {{ section.settings.bg_button }};
    color: {{ section.settings.color_button }};
    border: 1px solid {{ section.settings.border_color }};
  }
  .button_block-link.mobile:hover {
    background-color: {{ section.settings.bg_button_hover }};
    color: {{ section.settings.color_button_hover }};
    border: 1px solid {{ section.settings.border_color_hover }};
  }
</style>

<div class="row {% if full_width %}full-width-row-full{% endif %}">
  <div class="small-12 columns">
    <background-video class="background-video background-video-custom background-video--full-width-{{ full_width }} {{ mobile_height }} {{ desktop_height }} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}">
      {%- if fallback_image != blank -%}
        <div class="background-video__fallback-img">
          <img
            data-src="{{ fallback_image | image_url }}"
            alt="{{ fallback_image.alt | escape }}"
            width="{{ fallback_image.width }}"
            height="{{ fallback_image.height }}"
            class="lazyload{% unless settings.lazy_loading %} no-blur{% endunless %}"
          >
          <noscript>
            <img
              src="{{ fallback_image | image_url }}"
              alt="{{ fallback_image.alt | escape }}"
              width="{{ fallback_image.width }}"
              height="{{ fallback_image.height }}"
            >
          </noscript>
        </div>
      {%- endif -%}
      {%- if fallback_image_mobile != blank -%}
        <div class="background-video__fallback-img background-video__fallback-img--mobile">
          <img
            data-src="{{ fallback_image_mobile | image_url }}"
            alt="{{ fallback_image_mobile.alt | escape }}"
            width="{{ fallback_image_mobile.width }}"
            height="{{ fallback_image_mobile.height }}"
            class="lazyload{% unless settings.lazy_loading %} no-blur{% endunless %}"
          >
          <noscript>
            <img
              src="{{ fallback_image_mobile | image_url }}"
              alt="{{ fallback_image_mobile.alt | escape }}"
              width="{{ fallback_image_mobile.width }}"
              height="{{ fallback_image_mobile.height }}"
            >
          </noscript>
        </div>
      {%- endif -%}
      <div class="background-video__iframe" data-provider="{{ video_type }}">
        {%- if video_hosted == blank -%}
          {%- if video != blank -%}
            {%- if video.type == 'youtube' -%}
              <iframe
                data-src="https://www.youtube.com/embed/{{ video.id }}?loop=1&autoplay=1&mute=1&playlist={{ video.id }}&iv_load_policy=3&disablekb=1&controls=0&playsinline=1&enablejsapi=1"
                frameborder="0"
                class="lazyload"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ section.settings.heading | escape }}"
                tabindex="-1"
              ></iframe>
            {%- else -%}
              <iframe
                data-src="https://player.vimeo.com/video/{{ video.id }}?background=1"
                frameborder="0"
                class="lazyload"
                allow="autoplay; encrypted-media"
                allowfullscreen
                title="{{ section.settings.heading | escape }}"
                tabindex="-1"
              ></iframe>
            {%- endif -%}
          {%- endif -%}
        {%- else -%}
          {{ video_hosted | video_tag: autoplay: true, loop: true, controls: false, muted: true }}
        {%- endif -%}
      </div>
      <div
        class="background-video__overlay"
        style="--overlay-color-rgb: {{ overlay_color.rgb | replace: " ", "," }}; --overlay-opacity: {{ overlay_opacity | divided_by: 100.00 }}"
      ></div>
      <div class="background-video__content-wrap">
        <div class="background-video__content content-{{ section.settings.content_position }} alignment-{{ section.settings.content_alignment }} alignment-mobile-{{ section.settings.content_alignment_mobile }}">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'subheading' -%}
                <p class="subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- when 'heading' -%}
                <div class="block-info">
                  <h3 class="{{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text | newline_to_br }}
                  </h3>
                  <div
                    class="rte description description-size--{{ block.settings.description_size }}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.description }}
                  </div>
                </div>
              {%- when 'list_items' -%}
                <ul class="list-items">
                  <li class="list-items__item">
                    {%- if block.settings.item_image_1 != blank -%}
                      {{
                        block.settings.item_image_1
                        | image_url: width: 40, height: 40, crop: 'center'
                        | img_tag: alt: block.settings.item_text_1
                      }}
                    {%- endif -%}
                    {%- if block.settings.item_text_1 != blank -%}
                      {{ block.settings.item_text_1 }}
                    {%- endif -%}
                  </li>
                  <li class="list-items__item">
                    {%- if block.settings.item_image_2 != blank -%}
                      {{
                        block.settings.item_image_2
                        | image_url: width: 40, height: 40, crop: 'center'
                        | img_tag: alt: block.settings.item_text_2
                      }}
                    {%- endif -%}
                    {%- if block.settings.item_text_2 != blank -%}
                      {{ block.settings.item_text_2 }}
                    {%- endif -%}
                  </li>
                  <li class="list-items__item">
                    {%- if block.settings.item_image_3 != blank -%}
                      {{
                        block.settings.item_image_3
                        | image_url: width: 40, height: 40, crop: 'center'
                        | img_tag: alt: block.settings.item_text_3
                      }}
                    {%- endif -%}
                    {%- if block.settings.item_text_3 != blank -%}
                      {{ block.settings.item_text_3 }}
                    {%- endif -%}
                  </li>
                  <li class="list-items__item">
                    {%- if block.settings.item_image_4 != blank -%}
                      {{
                        block.settings.item_image_4
                        | image_url: width: 40, height: 40, crop: 'center'
                        | img_tag: alt: block.settings.item_text_4
                      }}
                    {%- endif -%}
                    {%- if block.settings.item_text_4 != blank -%}
                      {{ block.settings.item_text_4 }}
                    {%- endif -%}
                  </li>
                  <li class="list-items__item">
                    {%- if block.settings.item_image_5 != blank -%}
                      {{
                        block.settings.item_image_5
                        | image_url: width: 40, height: 40, crop: 'center'
                        | img_tag: alt: block.settings.item_text_5
                      }}
                    {%- endif -%}
                    {%- if block.settings.item_text_5 != blank -%}
                      {{ block.settings.item_text_5 }}
                    {%- endif -%}
                  </li>
                </ul>
              {%- when 'button' -%}
                <modal-opener
                  class="video-lightbox-modal__opener no-js-hidden"
                  data-modal="#VideoLightbox-{{ section.id }}"
                >
                  <button
                    id="VideoLightboxToggle-{{ section.id }}"
                    class="video-lightbox-modal__button video-lightbox-modal__button-custom"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    {% render 'svg-icons' with 'thb-video-play' %}
                    {{ block.settings.button_text }}
                  </button>
                  <style>
                    .video-lightbox-modal__button-custom {
                      background-color: {{ block.settings.bg_button_video }} !important;
                      color: {{ block.settings.color_button_video }}!important;
                      border: 1px solid {{ block.settings.border_color_video }}!important;
                    }
                    .video-lightbox-modal__button-custom:hover {
                      background-color: {{ block.settings.bg_button_video_hover }}!important;
                      color: {{ block.settings.color_button_video_hover }}!important;
                      border: 1px solid {{ block.settings.border_color_video_hover }}!important;
                    }
                    .video-lightbox-modal__button-custom svg path {
                      fill: {{ block.settings.color_button_video }} !important;
                    }
                    .video-lightbox-modal__button-custom:hover svg path {
                      fill: {{ block.settings.color_button_video_hover }} !important;
                    }
                  </style>
                  <a href="{{ section.settings.button_link }}" class="button button_block-link accent mobile">
                    {{ section.settings.button_text }}
                  </a>
                </modal-opener>
                <a href="{{ video.url }}" class="video-lightbox-modal__button no-js" target="_blank">
                  {%- render 'svg-icons' with 'thb-video-play' -%}
                </a>
                <modal-dialog id="VideoLightbox-{{ section.id }}" class="video-lightbox-modal">
                  <div
                    role="dialog"
                    aria-modal="true"
                    class="video-lightbox-modal__content"
                    tabindex="-1"
                  >
                    <button
                      id="ModalClose-{{ section.id }}"
                      type="button"
                      class="video-lightbox-modal__toggle"
                      aria-label="{{ 'accessibility.close' | t }}"
                    >
                      {% render 'svg-icons' with 'close' %}
                    </button>
                    <div class="video-lightbox-modal__content-info">
                      {%- if video_hosted == blank -%}
                        {%- if video.type == 'youtube' -%}
                          <iframe
                            data-src="https://www.youtube.com/embed/{{ video.id }}?enablejsapi=1"
                            class="js-youtube lazyload"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                          ></iframe>
                        {%- else -%}
                          <iframe
                            data-src="https://player.vimeo.com/video/{{ video.id }}"
                            class="js-vimeo lazyload"
                            allow="autoplay; encrypted-media"
                            allowfullscreen
                          ></iframe>
                        {%- endif -%}
                      {%- else -%}
                        {{ video_hosted | video_tag: autoplay: false, loop: false, controls: true }}
                      {%- endif -%}
                    </div>
                  </div>
                </modal-dialog>
                <script src="{{ 'modal-dialog.js' | asset_url }}" defer="defer"></script>
              {% when 'space' %}
                <div style="height: {{ block.settings.height | append: 'px' }}" {{ block.shopify_attributes }}></div>
            {%- endcase -%}
          {% endfor %}
        </div>
      </div>
      {% if video_controls %}
        <div class="background-video__controls">
          <button id="VideoPlayToggle-{{ section.id }}" type="button">
            <span class="background-video__controls-play">{% render 'svg-icons' with 'thb-video-play' %}</span>
            <span class="background-video__controls-pause">{% render 'svg-icons' with 'thb-video-pause' %}</span>
          </button>
        </div>
      {% endif %}
      <div class="button_block">
        {%- if section.settings.button_link -%}
          <a href="{{ section.settings.button_link }}" class="button button_block-link">
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>
    </background-video>
    <ul class="list-items list-items-mobile" style="background-color:{{ section.settings.bg_list }}">
      <li class="list-items__item">
        {%- if section.settings.item_image_1 != blank -%}
          {{
            section.settings.item_image_1
            | image_url: width: 40, height: 40, crop: 'center'
            | img_tag: alt: section.settings.item_text_1
          }}
        {%- endif -%}
        {%- if section.settings.item_text_1 != blank -%}
          {{ section.settings.item_text_1 }}
        {%- endif -%}
      </li>
      <li class="list-items__item">
        {%- if section.settings.item_image_2 != blank -%}
          {{
            section.settings.item_image_2
            | image_url: width: 40, height: 40, crop: 'center'
            | img_tag: alt: section.settings.item_text_2
          }}
        {%- endif -%}
        {%- if section.settings.item_text_2 != blank -%}
          {{ section.settings.item_text_2 }}
        {%- endif -%}
      </li>
      <li class="list-items__item">
        {%- if section.settings.item_image_3 != blank -%}
          {{
            section.settings.item_image_3
            | image_url: width: 40, height: 40, crop: 'center'
            | img_tag: alt: section.settings.item_text_3
          }}
        {%- endif -%}
        {%- if section.settings.item_text_3 != blank -%}
          {{ section.settings.item_text_3 }}
        {%- endif -%}
      </li>
      <li class="list-items__item">
        {%- if section.settings.item_image_4 != blank -%}
          {{
            section.settings.item_image_4
            | image_url: width: 40, height: 40, crop: 'center'
            | img_tag: alt: section.settings.item_text_4
          }}
        {%- endif -%}
        {%- if section.settings.item_text_4 != blank -%}
          {{ section.settings.item_text_4 }}
        {%- endif -%}
      </li>
      <li class="list-items__item">
        {%- if section.settings.item_image_5 != blank -%}
          {{
            section.settings.item_image_5
            | image_url: width: 40, height: 40, crop: 'center'
            | img_tag: alt: section.settings.item_text_5
          }}
        {%- endif -%}
        {%- if section.settings.item_text_5 != blank -%}
          {{ section.settings.item_text_5 }}
        {%- endif -%}
      </li>
    </ul>
  </div>
</div>
{{- 'background-video.css' | asset_url | stylesheet_tag -}}
{{- 'background-video-custom.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'background-video.js' | asset_url }}" defer="defer"></script>
{% schema %}
{
