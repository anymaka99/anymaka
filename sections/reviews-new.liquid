{{- 'customer-reviews.css' | asset_url | stylesheet_tag -}}
{%- liquid
  assign section_heading = section.settings.heading
  assign section_description = section.settings.description
  assign columns = section.settings.columns
  assign autoplay = section.settings.autoplay
  assign color_heading = section.settings.color_heading
  assign color_text = section.settings.color_text
  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing

  if autoplay
    assign autoplay = section.settings.autoplay_length | times: 1000
  endif

  assign color_bg = section.settings.color_bg | downcase
  assign color_body_bg = settings.color_body_bg | downcase

  assign has_bg = true
  if color_body_bg == color_bg or color_bg == 'transparent' or color_bg == 'rgba(0,0,0,0)'
    assign has_bg = false
  endif

  case columns
    when 3
      assign columns_class = 'medium-4'
    when 4
      assign columns_class = 'medium-6 large-3'
    when 5
      assign columns_class = 'medium-1/5 large-1/5'
    when 6
      assign columns_class = 'medium-3 large-2'
  endcase
-%}

<customer-reviews
  class="reviews-new-{{ section.id }} customer-reviews section-spacing-padding{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %} {% if section.settings.content_for_tab != blank %} product-tabs-content js-product-tabs-content-{{ section.settings.content_for_tab }}{% endif %}"
  style="--color-bg:{{ color_bg }}; --color-heading:{{ color_heading }}; --color-text:{{ color_text }}; --dot-speed: {{ autoplay | divided_by: 1000 | append: 's' }};"
>
  <div class="row">
    <div class="small-12 columns">
      {%- render 'section-header', section_heading: section_heading, section_description: section_description -%}
      <!-- data-flickity='{ "wrapAround": true, "cellAlign": "left","contain": true, "prevNextButtons": false, "pageDots": false }' -->
      <slide-show class="customer-reviews--carousel {% if section.settings.show_nav_mobile %} carousel-nav-mobile{% endif %}" data-autoplay="{{ autoplay }}" data-align="left" data-contain="true" data-wrapAround="true">
        {%- for block in section.blocks -%}

          <div class="small-12 columns carousel__slide carousel__slide-new">
            <div
              class="customer-reviews--review {% if has_bg -%}customer-reviews--review--has-bg{% endif %}"
              {{ block.shopify_attributes }}
            >

              <div class="customer-reviews--content customer-reviews--content-new">
                <div class="customer-reviews--content-image">
                  {%- if block.settings.author != blank -%}
                    <div class="customer-reviews--author-larger">
                      {%- if block.settings.author_image != blank -%}
                        {% assign image_class = "" %}
                        {%- if block.settings.author_image_mobile != blank -%}
                          {% assign image_class = "div-label--desktop" %}
                        {%- endif -%}
                        {%- render 'responsive-image', image: block.settings.author_image, sizes: '640x', class: image_class -%}
                      {%- endif -%}
                      
                      {%- if block.settings.author_image_mobile != blank -%}
                        {%- render 'responsive-image', image: block.settings.author_image_mobile, sizes: '640x', class: 'div-label--mobile' -%}
                      {%- endif -%}
                      
                    </div>
                  {%- endif -%} 
                </div>
                <div class="customer-reviews--content-txt">
                  {%- if block.settings.stars and block.settings.stars != '' -%}
                    <div class="star-rating" style="--star-rating: {{ block.settings.stars }};"></div>
                  {%- endif -%}
                  {%- if block.settings.heading != blank -%}
                    <h5 class="h5 {{ section.settings.block_heading_font }}">{{ block.settings.heading }}</h5>
                  {%- endif -%}
                  <div class="customer-reviews--author mb1 accent-text {{ section.settings.block_name_font }}">
                    <span>{{- block.settings.author -}}</span>
                  </div>          
                  <p class="{{ section.settings.block_description_font }}">{{ block.settings.text | newline_to_br }}</p>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
        {%- if section.blocks.size > columns -%}
          <div class="flickity-nav flickity-prev" tabindex="0">{% render 'svg-icons' with 'carousel-prev' %}</div>
          <div class="flickity-nav flickity-next" tabindex="0">{% render 'svg-icons' with 'carousel-next' %}</div>
        {%- endif -%}
      </slide-show>
    </div>
  </div>
</customer-reviews>
<style>
  .reviews-new-{{ section.id }} .customer-reviews--content.customer-reviews--content-new{
      background: {{ section.settings.review_color_bg }};
      height: 100%;
  }
  @media only screen and (max-width: 767px){
    {%- if section.settings.mobile_height -%}
   .reviews-new-{{ section.id }} .customer-reviews--carousel .columns.carousel__slide-new {
      height: {{ section.settings.mobile_height}}px;
    } 
    {%- endif -%}
  }
</style>
