{{ 'built-on-trust.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .trust {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }

    @media (max-width: 1067px) {
      #shopify-section-{{ section.id }} .trust {
        padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      }
    }
</style>

<section class="trust">
  {% if section.settings.title != blank %}
    <h2 class="trust__title">{{ section.settings.title }}</h2>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="trust__grid">
      {% for block in section.blocks %}
        <div class="trust__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="trust__icon-box">
              <img
                src="{{ block.settings.icon | image_url: width: 64 }}"
                alt="{{ block.settings.heading | escape }}"
                class="trust__icon"
                loading="lazy"
              >
            </div>
          {% endif %}

          <div class="trust__content">
            {% if block.settings.heading != blank %}
              <h3>{{ block.settings.heading }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}
          </div>

          {% if block.settings.button_label != blank %}
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="trust__button"
            >
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Built On Trust",
  "tag": "section",
  "class": "section-built-on-trust",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section heading",
      "default": "Built on Trust"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Return Order"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Read more about our return policy."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Built On Trust",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
